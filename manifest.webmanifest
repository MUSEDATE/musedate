{
  "name": "Ditto | Tell us your type, we set up the date",
  "short_name": "Ditto AI",
  "description": "A good friend that sets you up on real dates with your ideal type",
  "start_url": "/",
  "scope": "/",
  "scope_extensions": [
    { "origin": "https://ditto.ai" },
    { "origin": "https://www.ditto.ai" },
    { "origin": "https://app.ditto.ai" }
  ],
  "icons": [
    {
      "src": "/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "theme_color": "#ffffff",
  "background_color": "#F6F6F0",
  "display": "standalone"
}
